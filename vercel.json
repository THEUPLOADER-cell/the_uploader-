{
  "redirects": [
    {
      "source": "/:path((?!404).*)",
      "has": [
        {
          "type": "host",
          "value": "www.theuploader.in"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.theuploader.in/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "theuploader.in"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.theuploader.in/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "theuploader.in"
        }
      ],
      "destination": "https://www.theuploader.in/:path",
      "permanent": true
    },
    {
      "source": "/image-converter",
      "destination": "/image-format-converter",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
